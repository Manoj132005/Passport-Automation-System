# Deployment Environment Variables
# --------------------------------
# Create a copy of this file named ".env" and fill in the values below.
# DO NOT commit your ".env" file to Git.

PORT=3000
SECRET_KEY=your_super_secret_jwt_key_here

# PostgreSQL Database
# Format: postgres://username:password@hostname:port/database_name
# If using Render, this is provided automatically or when you create a DB.
DATABASE_URL=postgres://user:pass@localhost:5432/passport_db

# Cloudinary Setup for image/document uploads
# Get these by signing up at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

NODE_ENV=development
